# Copy to .env — never commit real secrets

NODE_ENV=production
PORT=3000

# Supabase (recommended): paste pooled connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DB_SSL=true
DB_SYNCHRONIZE=false

# Or local / split vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_NAME=ice_cream_franchise
# DB_SYNCHRONIZE=true

# Generate: openssl rand -base64 64
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Comma-separated if needed: https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# PhonePe — use mock mode for Phase 1 (free launch)
PHONEPE_MOCK_MODE=true
PHONEPE_ENV=production
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_STORE_ID=
PHONEPE_TERMINAL_ID=
PHONEPE_PROVIDER_ID=
PHONEPE_CALLBACK_URL=https://api.yourdomain.com/api/payments/phonepe/callback
PHONEPE_QR_EXPIRES_IN=300
